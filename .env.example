# Copie para .env local (não commitar .env)

# ── Obrigatórias em produção (Railway) ──────────────────

# URL do PostgreSQL — no Railway use referência do plugin:
#   ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://finapp:finapp@localhost:5432/finapp

# Segredo JWT — gere com: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Ambiente
NODE_ENV=development

# ── Automáticas (não precisa definir no Railway) ────────

# PORT — Railway define automaticamente
PORT=3001

# ── Opcionais ───────────────────────────────────────────

# Desabilitar seed do usuário demo em produção (padrão: cria se não existir)
# SEED_DEMO_USER=false
